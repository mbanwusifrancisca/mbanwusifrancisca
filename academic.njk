---
layout: base.njk
title: Academic Engagement
permalink: /academic/
---
<section class="block first">
  <div class="wrap-narrow">
    <p class="eyebrow">Academic Engagement</p>
    <p class="block-lede">This is where I document my academic engagement with health systems, health policy, and health informatics. Everything published here reflects what I'm learning, researching, questioning, or trying to understand better.</p>

    <div class="post-list">
      {%- set count = 0 -%}
      {%- for post in collections.posts -%}
        {%- if post.data.section == "academic" -%}
          {%- set count = count + 1 -%}
          <a class="post-card" href="{{ post.url }}">
            {% if post.data.tags %}<p class="post-tags">{{ post.data.tags | tagline }}</p>{% endif %}
            <h3 class="post-title">{{ post.data.title }}</h3>
            {% if post.data.subtitle %}<p class="post-sub">{{ post.data.subtitle }}</p>{% endif %}
            <p class="post-meta">{{ post.date | readableDate }} · {{ post.data.readingTime or (post.templateContent | readingTime) }}</p>
          </a>
        {%- endif -%}
      {%- endfor -%}
      {%- if count == 0 -%}<p class="empty">Posts will appear here.</p>{%- endif -%}
    </div>
  </div>
</section>
